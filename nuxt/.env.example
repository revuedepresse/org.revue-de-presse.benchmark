# Upstream highlights API. The Nitro server reads these and proxies
# /api/highlights → ${NUXT_API_BASE_URL}/api/twitter/highlights, attaching
# x-auth-token on the way. Neither value reaches the browser.
NUXT_API_BASE_URL=https://api.revue-de-presse.org
NUXT_API_AUTH_TOKEN=replace-with-the-x-auth-token-value
