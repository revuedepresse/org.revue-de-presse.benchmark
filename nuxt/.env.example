# Upstream highlights API (API Platform). The Nitro server reads these and proxies
# /api/highlights → ${NUXT_API_BASE_URL}/api/highlights, attaching a short-lived
# Bearer access token that it mints from ${NUXT_API_BASE_URL}/api/token using
# NUXT_API_CLIENT_SECRET as the long-lived client credential. The secret never
# reaches the browser.
NUXT_API_BASE_URL=https://api.revue-de-presse.org
NUXT_API_CLIENT_SECRET=replace-with-the-shared-client-secret
