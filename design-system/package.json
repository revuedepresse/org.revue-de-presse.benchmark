{
  "name": "@revue-de-presse/design-system-monorepo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build:tokens": "node scripts/sync-tokens.mjs --check",
    "tokens:sync": "node scripts/sync-tokens.mjs --write",
    "build:mitosis": "mitosis build && node scripts/post-mitosis.mjs",
    "build": "pnpm build:tokens && pnpm build:mitosis",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "demo": "pnpm --filter @revue-de-presse/design-system-demo dev",
    "story": "histoire dev --config stories/histoire.config.ts"
  },
  "devDependencies": {
    "@angular/common": "^18",
    "@angular/core": "^18",
    "@builder.io/mitosis": "^0.13.0",
    "@builder.io/mitosis-cli": "^0.13.0",
    "@builder.io/qwik": "^1.5",
    "@histoire/plugin-vue": "^0.17.17",
    "@stencil/core": "^4",
    "@types/node": "^20.14.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@zxcvbn-ts/core": "^3",
    "@zxcvbn-ts/language-common": "^3",
    "@zxcvbn-ts/language-en": "^3",
    "@zxcvbn-ts/language-fr": "^3",
    "alpinejs": "^3",
    "histoire": "^0.17.17",
    "lit": "^3.2.0",
    "playwright": "^1.59.1",
    "preact": "^10",
    "solid-js": "^1.9.0",
    "svelte": "^5.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "vue": "^3.5.0"
  }
}
