{
  "color": {
    "white": "#fff",
    "black": "#000",
    "brand": "#006663",
    "brand-active": "#00cdc7",
    "content-text": "#2f394d",
    "content-background": "#2f394d",
    "content-font": "#e6e6e6",
    "light-grey": "#657786",
    "taupe-grey": "#ebeef0",
    "border": "#e6e6e6",
    "background-other-month": "#e6e6e6",
    "background-future-date": "#fff",
    "error": "#ffaa00",
    "brand-bluesky": "#1d9bf0",
    "vanity-metric-like": "#851430",
    "vanity-metric-retweet": "#09442c",
    "vanity-metric-reply": "#1d9bf0"
  },
  "separation": {
    "0": "6px",
    "1": "8px",
    "2": "16px",
    "3": "19px"
  },
  "margin": {
    "status": "15px",
    "title": "20px",
    "navigation": "10px"
  },
  "radius": {
    "default": "8px",
    "date-picker": "4px",
    "selectable": "4px"
  },
  "line-height": {
    "base": "1.4em"
  },
  "font-size": {
    "content": "14px",
    "status-text": "19px",
    "publication-date": "12px",
    "calendar-month-day": "12px",
    "calendar-month-day-cell": "16px",
    "vanity-metric": "15px",
    "date-picker": "16px",
    "footer-paragraph": "16px",
    "footer-title": "26px",
    "footer-copyright": "12px",
    "footer-outer-link": "14px"
  },
  "button": {
    "bg-primary": "var(--color-brand-active)",
    "bg-primary-hover": "var(--color-brand)",
    "fg-primary": "var(--color-white)",
    "bg-secondary": "transparent",
    "border-secondary": "var(--color-brand-active)",
    "bg-disabled": "var(--color-background-other-month)"
  },
  "input": {
    "border-default": "var(--color-border)",
    "border-error": "var(--color-vanity-metric-like)",
    "bg-default": "var(--color-white)",
    "fg-default": "var(--color-content-text)"
  },
  "form-error": {
    "fg": "var(--color-vanity-metric-like)"
  },
  "alert": {
    "bg-empty": "var(--color-error)",
    "fg-empty": "var(--color-content-text)"
  },
  "banner-about": {
    "bg": "var(--color-content-background)",
    "fg": "var(--color-content-font)"
  }
}
